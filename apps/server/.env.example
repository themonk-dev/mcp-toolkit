# =============================================================================
# @mcp-toolkit/server — grouped JSON configuration
# =============================================================================
# Copy to apps/server/.env and edit. Each env var below carries a JSON-encoded
# object grouped by what gets edited together. Defaults kick in for unset keys;
# missing required fields surface validation errors at boot with a path that
# names the namespace (e.g. `server.port`).
#
# Shells require single-quoting the JSON so backslashes and spaces survive.
# Multi-line policy YAML is best loaded via POLICY.path on Node (see below).
#
# Layout:
#   SERVER             — networking; set once per deployment
#   RUNTIME            — env knobs that change per environment
#   AUTH               — strategy selection (one of: none / apikey / bearer / custom / jwt / oidc)
#   AUTH_KEYS          — pre-shared credentials (apikey / bearer / custom / jwt)
#   AUTH_OAUTH         — OAuth + OIDC stack (only when strategy=oidc or oauth)
#   MCP                — server identity returned on initialize
#   MCP_ICON           — optional SEP-973 icon
#   STORAGE            — token store (Node: file-backed; Workers: KV bindings)
#   POLICY             — access policy (inline content or, on Node, a file path)
#   CONNECTED_SERVERS  — downstream MCP servers to proxy (one upstream tool per entry)

# -----------------------------------------------------------------------------
# Networking
# -----------------------------------------------------------------------------
SERVER='{"host":"127.0.0.1","port":3000,"allowedOrigins":[]}'

# -----------------------------------------------------------------------------
# Runtime knobs
# -----------------------------------------------------------------------------
RUNTIME='{"nodeEnv":"development","logLevel":"info","rpsLimit":0,"concurrencyLimit":0}'

# -----------------------------------------------------------------------------
# Auth — strategy selection
# -----------------------------------------------------------------------------
# Default: anonymous mode. Switch the `strategy` value to enable auth; the
# matching AUTH_KEYS or AUTH_OAUTH section then applies.
#   strategy: none | apikey | bearer | custom | jwt | oidc
#   requireRs (oidc only): reject Bearers that aren't mapped to an RS token
#   resourceUri / discoveryUrl: override .well-known/oauth-protected-resource
AUTH='{"strategy":"none","requireRs":false}'

# -----------------------------------------------------------------------------
# Auth — pre-shared credentials (apikey / bearer / custom / jwt strategies)
# -----------------------------------------------------------------------------
# Only the sub-object matching AUTH.strategy is read; safe to leave the others
# empty.
AUTH_KEYS='{
  "apikey": { "key": "", "headerName": "x-api-key" },
  "bearer": { "token": "" },
  "custom": { "headers": "" },
  "jwt":    { "jwksUrl": "", "issuer": "", "audience": "" }
}'

# -----------------------------------------------------------------------------
# Auth — OAuth / OIDC stack (oidc / oauth strategies)
# -----------------------------------------------------------------------------
# Only read when AUTH.strategy = "oidc" or "oauth".
#   oauth.clientAuth: "basic" (default) or "post"
#   oauth.redirectAllowlist: array of allowed redirect_uri values (CORS-style)
#   cimd: SEP-991 dynamic client_id verification — leave enabled in production
AUTH_OAUTH='{
  "oauth": {
    "clientId": "",
    "clientSecret": "",
    "scopes": "",
    "authorizationUrl": "",
    "tokenUrl": "",
    "revocationUrl": "",
    "redirectUri": "http://localhost:3000/callback",
    "redirectAllowlist": [],
    "redirectAllowAll": false,
    "clientAuth": "basic",
    "extraAuthParams": ""
  },
  "oidc": { "issuer": "" },
  "provider": { "clientId": "", "clientSecret": "", "accountsUrl": "" },
  "cimd": { "enabled": true, "fetchTimeoutMs": 5000, "maxResponseBytes": 65536, "allowedDomains": [] }
}'

# -----------------------------------------------------------------------------
# MCP — server identity (returned on initialize handshake)
# -----------------------------------------------------------------------------
MCP='{"title":"My MCP Server","version":"1.0.0","instructions":"Use these tools responsibly.","protocolVersion":"2025-06-18"}'

# -----------------------------------------------------------------------------
# MCP — icon (optional, SEP-973). Drop the var entirely if you don't need one.
# -----------------------------------------------------------------------------
# MCP_ICON='{"url":"https://img.icons8.com/?size=512&id=41523&format=png","mime":"image/png","sizes":["512x512"]}'

# -----------------------------------------------------------------------------
# Storage — token persistence (Node)
# -----------------------------------------------------------------------------
# Workers ignores tokensFile entirely — wire TOKENS + SESSIONS KV bindings in
# wrangler.toml instead. The tokensEncKey is honored in both runtimes.
# Generate a key with:
#   openssl rand -base64 32 | tr -d '=' | tr '+/' '-_'
STORAGE='{"tokensFile":".data/tokens.json","tokensEncKey":""}'

# -----------------------------------------------------------------------------
# Policy — access control (off by default → full catalog visible)
# -----------------------------------------------------------------------------
# Two equivalent shapes:
#   POLICY='{"content":"<inline YAML or JSON>"}'              (any runtime)
#   POLICY='{"path":"./policy/mcp-access.example.yaml"}'       (Node only)
# With mode: enforce, only catalog entries matched by an allow rule are
# visible (default-deny). See policy/ for examples.
POLICY='{"content":""}'

# =============================================================================
# Worked examples
# =============================================================================

# -----------------------------------------------------------------------------
# Example: apikey strategy
# -----------------------------------------------------------------------------
# AUTH='{"strategy":"apikey"}'
# AUTH_KEYS='{"apikey":{"key":"replace-me","headerName":"x-api-key"}}'

# -----------------------------------------------------------------------------
# Example: bearer strategy
# -----------------------------------------------------------------------------
# AUTH='{"strategy":"bearer"}'
# AUTH_KEYS='{"bearer":{"token":"replace-me"}}'

# -----------------------------------------------------------------------------
# Example: jwt strategy
# -----------------------------------------------------------------------------
# AUTH='{"strategy":"jwt"}'
# AUTH_KEYS='{"jwt":{"jwksUrl":"https://your-idp.example/.well-known/jwks.json","issuer":"https://your-idp.example/","audience":"your-audience"}}'

# -----------------------------------------------------------------------------
# Example: OIDC strategy against JumpCloud
# -----------------------------------------------------------------------------
# AUTH='{"strategy":"oidc","requireRs":true}'
# AUTH_OAUTH='{
#   "oauth": { "clientAuth": "post", "scopes": "openid profile email", "redirectUri": "http://localhost:3000/callback" },
#   "oidc":  { "issuer": "https://oauth.id.jumpcloud.com/" },
#   "provider": { "clientId": "YOUR_CLIENT_ID", "clientSecret": "YOUR_CLIENT_SECRET" }
# }'

# -----------------------------------------------------------------------------
# Example: enforce policy from a file (Node)
# -----------------------------------------------------------------------------
# POLICY='{"path":"./policy/mcp-access.example.yaml"}'

# -----------------------------------------------------------------------------
# Connected downstream MCP servers
# -----------------------------------------------------------------------------
# Each entry becomes one upstream tool named by `id`. The handler lazily
# discovers the downstream's tool list and forwards `tools/call` to it,
# injecting the configured credential.
#
# Supported authType values:
#   none     — no auth header injected
#   api_key  — sets a custom header: { headerName, key }
#   bearer   — sets `Authorization: Bearer <token>`: { token }
#
# OAuth2 is not supported yet; add it as a new authType variant when the
# discovery / DCR / refresh layer lands.
#
# Missing secrets (empty `token` / `key`) fail at boot with a clear path-
# prefixed error like `connectedServers.0.token: ...`.
CONNECTED_SERVERS='[]'

# Example shape (substitute your own id / url / credential per entry):
# CONNECTED_SERVERS='[
#   {"id":"<server-id-1>","url":"https://<host>/<mcp-path>","authType":"bearer","token":"<token>"},
#   {"id":"<server-id-2>","url":"https://<host>/<mcp-path>","authType":"api_key","headerName":"<header-name>","key":"<key>"},
#   {"id":"<server-id-3>","url":"https://<host>/<mcp-path>","authType":"none"}
# ]'
