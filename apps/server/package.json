{
  "name": "@mcp-toolkit/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Runnable MCP server: composes @mcp-toolkit/* packages for Node and Cloudflare Workers.",
  "scripts": {
    "dev": "bun --hot src/main.ts",
    "dev:worker": "wrangler dev",
    "start": "bun run src/main.ts",
    "build": "bun build src/main.ts --outdir dist --target bun",
    "deploy": "wrangler deploy",
    "deploy:tail": "wrangler tail",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@mcp-toolkit/auth": "workspace:*",
    "@mcp-toolkit/core": "workspace:*",
    "@mcp-toolkit/mcp": "workspace:*",
    "@mcp-toolkit/mcp-client": "workspace:*",
    "@mcp-toolkit/policy": "workspace:*",
    "@mcp-toolkit/prompts": "workspace:*",
    "@mcp-toolkit/proxy-tools": "workspace:*",
    "@mcp-toolkit/resources": "workspace:*",
    "@mcp-toolkit/storage": "workspace:*",
    "@mcp-toolkit/tools": "workspace:*",
    "@mcp-toolkit/transport-http": "workspace:*",
    "@hono/node-server": "^1.13.1",
    "hono": "^4.8.12",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "jose": "^6.1.3"
  }
}
